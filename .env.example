# AgentZ environment variables (all optional).
# Copy to `.env` for local development; none are required to run.

# ── Storage ──────────────────────────────────────────────────────────────────
# Override the global config / data directory (agents, teams, workflow runs).
# Defaults to the OS app-config dir for AgentZ.
AGENTZ_CONFIG_DIR=

# ── Logging ──────────────────────────────────────────────────────────────────
# tracing/env-filter directive. Examples: "info", "agentz_desktop=debug,info".
RUST_LOG=info

# ── Agent runtime ─────────────────────────────────────────────────────────────
# Max number of agent (koi) turns running concurrently.
CODEZ_AGENT_CONCURRENCY=
# Opt in to automatic model routing (stronger model for harder turns): set to 1.
CODEZ_AUTO_MODEL_ROUTING=

# ── Extension host (Node sidecar) ─────────────────────────────────────────────
# Explicit path to the built extension host bundle (extension-host/dist/host.js).
CODEZ_EXT_HOST_JS=
# Node executable used to launch the extension host. Defaults to "node" on PATH.
CODEZ_NODE=

# ── Browser tool (Chrome/Chromium) ────────────────────────────────────────────
# Path to the Chrome/Chromium executable for the built-in browser tool.
# Also honored: CHROME, GOOGLE_CHROME_BIN.
CODEZ_CHROME=
